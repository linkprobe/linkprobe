{
  "name": "linkprobe",
  "private": true,
  "license": "MIT",
  "author": {
    "name": "Hossein-i",
    "email": "sayhi@hossein-i.ir",
    "url": "https://www.hossein-i.ir/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/linkprobe/linkprobe.git"
  },
  "bugs": {
    "url": "https://github.com/linkprobe/linkprobe/issues",
    "email": "sayhi@hossein-i.ir"
  },
  "homepage": "https://github.com/linkprobe/linkprobe",
  "scripts": {
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo lint -- --fix",
    "format": "prettier --ignore-path .prettierignore --check .",
    "format:fix": "prettier --ignore-path .prettierignore --write .",
    "check-types": "turbo run check-types",
    "build": "turbo run build",
    "test": "turbo test",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:release": "changeset publish",
    "upli": "pnpm up --filter \"./**\"  -L -i",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@linkprobe/standard": "workspace:*",
    "@next/eslint-plugin-next": "^16.2.6",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "10.4.1",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-only-warn": "1.2.1",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-sort-destructure-keys": "3.0.0",
    "eslint-plugin-sort-keys-fix": "1.1.2",
    "eslint-plugin-storybook": "10.4.1",
    "eslint-plugin-unused-imports": "4.4.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "prettier-plugin-css-order": "^2.2.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.9.16",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.60.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
